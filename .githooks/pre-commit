#!/bin/sh

export PATH="$HOME/.cargo/bin:$PATH"

echo "Running cargo fmt check..."

if ! cargo fmt --all -- --check; then
    echo ""
    echo "ERROR: Code formatting check failed!"
    echo "Please run 'cargo fmt --all' or 'make fmt' to fix formatting issues."
    exit 1
fi

if ! cargo fmt --manifest-path desktop/src-tauri/Cargo.toml --all -- --check; then
    echo ""
    echo "ERROR: Desktop Tauri code formatting check failed!"
    echo "Please run 'cargo fmt --manifest-path desktop/src-tauri/Cargo.toml --all' or 'make fmt' to fix formatting issues."
    exit 1
fi

echo "Code formatting check passed."
exit 0
