{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bifrost",
  "version": "0.0.35-beta",
  "identifier": "com.bifrost.desktop",
  "build": {
    "frontendDist": "../../web/dist-desktop"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": []
  },
  "bundle": {
