{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bifrost",
  "version": "0.0.15-beta",
  "identifier": "com.bifrost.desktop",
  "build": {
    "frontendDist": "../../web/dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bifrost",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "transparent": true,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../assets/bifrost.png",
      "../../assets/bifrost.icns",
      "../../assets/bifrost.ico"
    ],
    "resources": [
      "resources/bin/*"
    ]
  }
}
