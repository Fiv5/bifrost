---
import "../styles/site.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const docsRoot = new URL("docs/", `https://bifrost.local${baseUrl}`).pathname;
const installationUrl = new URL(
  "getting-started/installation/",
  `https://bifrost.local${baseUrl}`,
).pathname;
const networkImageUrl = new URL(
  "images/network.png",
  `https://bifrost.local${baseUrl}`,
).pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Bifrost 是一个高性能 HTTP/HTTPS/SOCKS5 代理服务器，提供流量拦截、规则引擎、脚本扩展、TLS MITM 与可视化管理能力。"
    />
    <title>Bifrost | 高性能代理与流量调试平台</title>
    <link rel="icon" type="image/png" href={`${baseUrl}favicon.png`} />
  </head>
  <body>
    <div class="page-shell">
      <div class="page-noise"></div>
      <header class="site-header">
        <a class="brand" href={baseUrl}>
          <span class="brand-mark">B</span>
          <span>Bifrost</span>
        </a>
        <nav class="site-nav">
          <a href="#features">能力</a>
          <a href="#protocols">协议</a>
          <a href="#quickstart">快速开始</a>
          <a href={docsRoot}>文档</a>
          <a href="https://github.com/bifrost-proxy/bifrost">GitHub</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <div class="hero-copy">
            <div class="hero-badge">
              <span class="hero-badge-dot"></span>
              Modern Proxy Toolkit
            </div>
            <h1>为复杂流量调试而生的现代代理工作台。</h1>
            <p class="hero-text">
              Bifrost 把高性能代理、TLS MITM、规则引擎、脚本扩展和流量观察整合到一套
              更顺手的体验里。它适合接口联调、移动端抓包、协议排查、请求改写和桌面化日常使用。
            </p>
            <div class="hero-actions">
              <a class="primary-action" href={installationUrl}>开始使用</a>
              <a class="secondary-action" href="https://github.com/bifrost-proxy/bifrost"
                >查看源码</a
              >
            </div>
            <div class="hero-ledger">
              <div class="hero-ledger-item">
                <span>Rust Core</span>
                <strong>Tokio + Hyper + QuickJS</strong>
              </div>
              <div class="hero-ledger-item">
                <span>工作流</span>
                <strong>MITM / Rules / Replay / Scripts</strong>
              </div>
            </div>
          </div>

          <div class="hero-visual">
            <div class="hero-surface">
              <div class="surface-orb orb-left"></div>
              <div class="surface-orb orb-right"></div>
              <div class="surface-grid"></div>
            </div>
            <div class="visual-frame">
              <div class="visual-topline">
                <div class="visual-label">Product Preview</div>
                <div class="visual-chip">Desktop + Web UI</div>
              </div>
              <img
                src={networkImageUrl}
                alt="Bifrost product preview"
                class="hero-image"
                loading="eager"
              />
            </div>
            <div class="floating-card top">
              <span>Protocol Coverage</span>
              <strong>HTTP/1.1 · HTTP/2 · HTTP/3 · SOCKS5</strong>
            </div>
            <div class="floating-card bottom">
              <span>Debug Workflow</span>
              <strong>拦截、改写、脚本、回放一条链闭环</strong>
            </div>
          </div>
        </section>

        <section class="signal-strip">
          <div class="signal-card">
            <span>协议栈</span>
            <strong>HTTP / HTTPS / SOCKS5 / WebSocket / SSE</strong>
          </div>
          <div class="signal-card">
            <span>关键能力</span>
            <strong>TLS MITM / Rules / Script Sandbox / Replay</strong>
          </div>
          <div class="signal-card">
            <span>交付形态</span>
            <strong>CLI / Desktop / 管理端 UI</strong>
          </div>
        </section>

        <section class="feature-section" id="features">
          <div class="section-heading">
            <p class="eyebrow">Capabilities</p>
            <h2>不只是“代理一下”，而是一套真正可编排的流量系统。</h2>
          </div>
          <div class="feature-grid feature-grid-primary">
            <article class="feature-card feature-card-large">
              <h3>TLS MITM</h3>
              <p>自动生成 CA、动态签发证书，支持按域名精细控制拦截和透传。</p>
            </article>
            <article class="feature-card">
              <h3>Rules Engine</h3>
              <p>支持 Headers、Body、状态码、路由、Mock、延迟与限速。</p>
            </article>
            <article class="feature-card">
              <h3>Script Runtime</h3>
              <p>基于 QuickJS 的沙箱脚本能力，支持请求、响应和 decode 扩展。</p>
            </article>
            <article class="feature-card">
              <h3>Traffic Explorer</h3>
              <p>内置 Web UI，实时查看流量明细、消息体、脚本日志与搜索结果。</p>
            </article>
            <article class="feature-card feature-card-accent">
              <h3>Replay Workflow</h3>
              <p>请求回放与重试能力让接口对比、故障复现和回归验证更加直接。</p>
            </article>
            <article class="feature-card">
              <h3>Desktop Ready</h3>
              <p>桌面版基于 Tauri 打包，面向日常代理工作更轻量，也更易分发。</p>
            </article>
          </div>
        </section>

        <section class="protocol-section" id="protocols">
          <div class="section-heading">
            <p class="eyebrow">Protocol Matrix</p>
            <h2>覆盖真实代理场景里最常遇到的协议组合。</h2>
          </div>
          <div class="protocol-grid">
            <div><span>HTTP/1.1</span><strong>完整支持</strong></div>
            <div><span>HTTP/2</span><strong>多路复用与帧级处理</strong></div>
            <div><span>HTTP/3</span><strong>下游 H3 接入</strong></div>
            <div><span>HTTPS</span><strong>TLS 1.2 / 1.3 MITM</strong></div>
            <div><span>SOCKS5</span><strong>TCP / UDP Associate</strong></div>
            <div><span>WebSocket / SSE</span><strong>长连接与消息流调试</strong></div>
          </div>
        </section>

        <section class="quickstart-section" id="quickstart">
          <div class="section-heading">
            <p class="eyebrow">Quick Start</p>
            <h2>优先用最快的方式装上，再按你的场景深入。</h2>
          </div>
          <div class="quickstart-grid">
            <article class="install-card install-card-primary">
              <div class="install-card-head">
                <span>推荐安装</span>
                <strong>一键脚本</strong>
              </div>
              <pre><code>curl -fsSL https://raw.githubusercontent.com/bifrost-proxy/bifrost/main/install-binary.sh | bash</code></pre>
              <p>自动检测平台和架构，适合第一次快速体验 Bifrost CLI。</p>
              <a href={installationUrl}>查看全部安装选项</a>
            </article>

            <article class="install-card">
              <div class="install-card-head">
                <span>macOS</span>
                <strong>Homebrew</strong>
              </div>
              <pre><code>brew tap bifrost-proxy/bifrost
brew install bifrost</code></pre>
              <p>如果你已经在用 Homebrew 管理开发工具，这是更顺手的安装方式。</p>
              <a href={installationUrl}>查看安装说明</a>
            </article>

            <article class="install-card">
              <div class="install-card-head">
                <span>源码与桌面版</span>
                <strong>本地构建</strong>
              </div>
              <pre><code>git clone https://github.com/bifrost-proxy/bifrost.git
cd bifrost
./install.sh</code></pre>
              <p>适合需要 CLI、桌面端或准备参与贡献的用户，也方便查看完整文档。</p>
              <a href={docsRoot}>进入文档</a>
            </article>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
