---
import "../styles/site.css";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bifrost | 页面未找到</title>
    <link rel="icon" type="image/png" href={`${baseUrl}favicon.png`} />
  </head>
  <body>
    <main class="feature-section" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="section-heading">
        <p class="eyebrow">404</p>
        <h2>你访问的页面不存在，或者已经被移动。</h2>
      </div>
      <div class="quickstart-card" style="margin-top: 24px;">
        <div class="quickstart-copy">
          <p>可以从官网首页重新进入，或者直接跳到文档入口和参考文档。</p>
          <a href={baseUrl}>返回首页</a>
        </div>
        <pre><code>{`文档入口: ${baseUrl}docs/
快速开始: ${baseUrl}getting-started/overview/
参考文档: ${baseUrl}reference/`}</code></pre>
      </div>
    </main>
  </body>
</html>
