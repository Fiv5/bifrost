#!/bin/sh

echo "🔍 Running pre-commit checks..."
echo ""

echo "1/2 Checking code formatting (cargo fmt)..."
if ! cargo fmt --all -- --check; then
    echo ""
    echo "❌ Code formatting check failed!"
    echo "   Run 'cargo fmt --all' to fix formatting issues."
    exit 1
fi
echo "✅ Code formatting check passed."

echo ""
echo "2/2 Running clippy lints (cargo clippy)..."
if ! cargo clippy --workspace --all-targets --all-features -- -D warnings 2>&1; then
    echo ""
    echo "❌ Clippy check failed!"
    echo "   Please fix the clippy warnings above before committing."
    echo "   Hint: 'cargo clippy --fix --workspace --all-targets --all-features' can auto-fix some issues."
    exit 1
fi
echo "✅ Clippy check passed."

echo ""
echo "✅ All pre-commit checks passed."
exit 0
