{
  "name": "@aspect-build/bifrost-sync-server",
  "version": "1.0.0",
  "description": "Standalone Bifrost sync server for self-hosted rule synchronization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bifrost-sync-server": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "bifrost",
    "sync",
    "proxy",
    "rules"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.11.0",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
