#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_cmd_helper.sh"

if real_cmd="$(find_real_cmd python3)"; then
  exec "$real_cmd" "$@"
fi

if real_cmd="$(find_real_cmd python)"; then
  if "$real_cmd" -c 'import sys; raise SystemExit(0 if sys.version_info[0] >= 3 else 1)' >/dev/null 2>&1; then
    exec "$real_cmd" "$@"
  fi
fi

echo "python3 shim: neither python3 nor python>=3 found in PATH" >&2
exit 127
